{
  "name": "kotobank-mcp",
  "version": "0.1.0",
  "description": "Cloud-deployable HTTP-only MCP service for Kotobank dictionary lookup",
  "type": "module",
  "bin": {
    "kotobank-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run dev:http",
    "dev:http": "tsx src/index.ts",
    "prepare": "npm run build",
    "start": "npm run start:http",
    "start:http": "node dist/index.js",
    "docker:build": "docker build -t kotobank-mcp-service .",
    "docker:run": "docker run --rm -p 3000:3000 kotobank-mcp-service",
    "test": "vitest run",
    "test:live": "RUN_LIVE_KOTOBANK_TESTS=1 vitest run tests/live.smoke.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HenMie/kotobankMCP.git"
  },
  "homepage": "https://github.com/HenMie/kotobankMCP",
  "bugs": {
    "url": "https://github.com/HenMie/kotobankMCP/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cheerio": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
